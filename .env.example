# ============================================
# Job Scraper — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# Apify API Token (get from https://console.apify.com/account/integrations)
APIFY_API_TOKEN=your_apify_token_here

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_key_here

# OpenAI Model to use for resume rewriting
OPENAI_MODEL=gpt-4o-mini

# Schedule (cron expression) — Default: 9:00 AM daily
SCHEDULE_CRON=0 9 * * *

# Timezone for scheduler
TIMEZONE=Asia/Kolkata

# Maximum jobs to fetch per site
MAX_JOBS_PER_SITE=20

# Only fetch jobs posted within this many hours
JOB_AGE_HOURS=24

# Output directory for Excel files
OUTPUT_DIR=./output

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable desktop notifications (true/false)
NOTIFICATIONS_ENABLED=true
