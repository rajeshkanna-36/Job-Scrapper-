{
  "schedule": {
    "cron": "0 9 * * *",
    "timezone": "Asia/Kolkata",
    "description": "Runs daily at 9:00 AM IST"
  },
  "scraping": {
    "maxJobsPerSite": 20,
    "jobAgeHours": 24,
    "retryAttempts": 3,
    "retryDelayMs": 2000,
    "concurrentSites": 5
  },
  "ai": {
    "model": "gpt-4o-mini",
    "temperature": 0.3,
    "maxTokens": 2000,
    "concurrentRewrites": 5
  },
  "output": {
    "directory": "./output",
    "filenamePattern": "jobs_{date}.xlsx",
    "maxDescriptionLength": 500
  },
  "resume": {
    "directory": "./resume",
    "supportedFormats": [".pdf"]
  },
  "notifications": {
    "enabled": true,
    "title": "Job Scraper",
    "sound": true
  }
}
